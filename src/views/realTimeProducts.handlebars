<h1>Productos en Tiempo Real</h1>

<div class="panel-realtime">

    <div class="form-card">
        <h2>Agregar Producto</h2>
        <div class="campos">
            <input id="title"       type="text"   placeholder="Titulo *" />
            <input id="description" type="text"   placeholder="Descripcion *" />
            <input id="code"        type="text"   placeholder="Codigo *" />
            <input id="price"       type="number" placeholder="Precio *" />
            <input id="stock"       type="number" placeholder="Stock *" />
            <input id="category"    type="text"   placeholder="Categoria *" />
            <button class="btn-agregar" onclick="agregarProducto()">Agregar Producto</button>
        </div>
        <p id="mensaje" class="mensaje"></p>
    </div>

    <div class="lista-panel">
        <h2>Productos Actuales</h2>
        <div id="lista-productos">
            {{#each productos}}
            <div id="prod-{{this._id}}" class="producto-item">
                <div class="producto-info">
                    <strong>{{this.title}}</strong> — ${{this.price}}
                    <span> | {{this.category}} | Stock: {{this.stock}}</span>
                </div>
                <button class="btn-eliminar" onclick="eliminarProducto('{{this._id}}')">
                    Eliminar
                </button>
            </div>
            {{/each}}
        </div>
    </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();

    socket.on('actualizarProductos', (productos) => {
        const lista = document.getElementById('lista-productos');
        lista.innerHTML = '';

        if (!productos.length) {
            lista.innerHTML = '<p class="sin-productos">No hay productos.</p>';
            return;
        }

        productos.forEach(p => {
            lista.innerHTML += `
                <div id="prod-${p._id}" class="producto-item">
                    <div class="producto-info">
                        <strong>${p.title}</strong> — $${p.price}
                        <span> | ${p.category} | Stock: ${p.stock}</span>
                    </div>
                    <button class="btn-eliminar" onclick="eliminarProducto('${p._id}')">
                        Eliminar
                    </button>
                </div>
            `;
        });
    });

    function agregarProducto() {
        const producto = {
            title:       document.getElementById('title').value.trim(),
            description: document.getElementById('description').value.trim(),
            code:        document.getElementById('code').value.trim(),
            price:       parseFloat(document.getElementById('price').value),
            stock:       parseInt(document.getElementById('stock').value),
            category:    document.getElementById('category').value.trim(),
            status:      true,
            thumbnails:  []
        };

        if (!producto.title || !producto.description || !producto.code || !producto.price || isNaN(producto.stock) || !producto.category) {
            document.getElementById('mensaje').textContent = 'Completa todos los campos obligatorios.';
            document.getElementById('mensaje').style.color = 'orange';
            return;
        }

        socket.emit('nuevoProducto', producto);
        document.getElementById('mensaje').textContent = 'Producto enviado correctamente.';
        document.getElementById('mensaje').style.color = 'green';

        ['title','description','code','price','stock','category'].forEach(id => {
            document.getElementById(id).value = '';
        });
    }

    function eliminarProducto(id) {
        socket.emit('eliminarProducto', id);
    }
</script>
